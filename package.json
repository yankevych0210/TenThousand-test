{
  "name": "forms-lite",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --names \"server,client\" --prefix-colors \"blue,green\" \"pnpm --filter server dev\" \"pnpm --filter client dev\"",
    "build": "pnpm --filter server build && pnpm --filter client build",
    "start": "pnpm --filter server start",
    "codegen": "pnpm --filter client codegen",
    "typecheck": "pnpm --filter server typecheck && pnpm --filter client typecheck",
    "test": "pnpm --filter client test",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
